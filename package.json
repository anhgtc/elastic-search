{
  "name": "tvs-search-service",
  "version": "0.1.0",
  "description": "Hệ thống tìm kiếm độc lập cho Thư Viện Số (Elasticsearch) — đồng bộ từ MySQL gốc và cung cấp REST API tìm kiếm.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start:api": "cross-env APP_MODE=api node dist/main.js",
    "start:worker": "cross-env APP_MODE=worker node dist/main.js",
    "reindex": "cross-env APP_MODE=reindex node dist/main.js",
    "dev:api": "cross-env APP_MODE=api ts-node -r tsconfig-paths/register src/main.ts",
    "dev:worker": "cross-env APP_MODE=worker ts-node -r tsconfig-paths/register src/main.ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.13.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cross-env": "^7.0.3",
    "ioredis": "^5.3.2",
    "mysql2": "^3.9.2",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
