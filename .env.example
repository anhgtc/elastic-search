# ============================================================================
#  TVS SEARCH SERVICE — CẤU HÌNH MÔI TRƯỜNG
#  Copy file này thành `.env` rồi điền giá trị thật khi có hạ tầng.
#  "Cắm hạ tầng vào là chạy" — chỉ cần sửa các biến dưới đây.
# ============================================================================

# --- Vai trò container: api | worker | reindex ---
# api     : chạy REST API tìm kiếm (HTTP)
# worker  : chạy đồng bộ định kỳ (cron delta sync)
# reindex : chạy full reindex 1 lần rồi thoát (docker compose run)
APP_MODE=api

# --- HTTP server (chỉ dùng khi APP_MODE=api) ---
HTTP_PORT=3000
# Tiền tố API, ví dụ /api -> POST /api/search
API_PREFIX=

# Khóa bảo vệ API GHI (Ingest). Để trống = mở (chỉ nên khi dev).
# Bên thư viện số gửi kèm header: X-Ingest-Key: <khóa>
INGEST_API_KEY=

# ============================================================================
#  MYSQL GỐC — CHỈ CẦN cho chế độ PULL tùy chọn (APP_MODE=worker|reindex).
#  Ở chế độ api (Search + Ingest) search KHÔNG chạm DB gốc -> có thể bỏ qua.
# ============================================================================
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3307
MYSQL_USER=tvs_search_ro
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=digital_library
# Tiền tố bảng theo phpviet (mặc định các bảng là tvs_/core_ nên để trống)
MYSQL_TABLE_PREFIX=
MYSQL_CONNECTION_LIMIT=5

# ============================================================================
#  ELASTICSEARCH — đích đồng bộ + phục vụ tìm kiếm
#  Dev: dùng ES trong docker-compose (profile dev) -> http://elasticsearch:9200
#  Prod: trỏ ra ES hạ tầng cấp sau, điền URL + auth thật.
# ============================================================================
ELASTIC_NODE=http://elasticsearch:9200
ELASTIC_USERNAME=
ELASTIC_PASSWORD=
# Với ES 8 dùng TLS + self-signed cert, đặt false để bỏ verify (chỉ nội bộ)
ELASTIC_TLS_REJECT_UNAUTHORIZED=true
# Tên alias chính dùng để query. Index vật lý sẽ là <ALIAS>_v1, _v2...
ELASTIC_INDEX_ALIAS=tvs_documents

# ============================================================================
#  REDIS — lưu checkpoint đồng bộ + cache suggest
#  Có thể tái dùng Redis sẵn có hoặc dùng redis trong compose.
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Tiền tố key để tránh đụng key hệ thống khác
REDIS_KEY_PREFIX=tvs_search:

# ============================================================================
#  ĐỒNG BỘ (SYNC WORKER)
# ============================================================================
# Lịch cron delta sync (cú pháp cron 6 trường của @nestjs/schedule).
# Mặc định: mỗi 1 phút.
SYNC_CRON=*/1 * * * * *
# Số bản ghi mỗi batch khi quét delta
SYNC_BATCH_SIZE=1000
# Tự chạy full reindex khi worker khởi động lần đầu (nếu alias chưa tồn tại)
SYNC_BOOTSTRAP_REINDEX=true
# Bật/tắt worker chạy delta ngay khi start
SYNC_ENABLED=true
# Theo dõi thay đổi PHIẾU (ticket) để reindex ấn phẩm liên quan.
# Cần thiết vì khi phiếu đổi, tvs_document.updated_date KHÔNG đổi -> delta thường bỏ sót.
SYNC_DEPS_ENABLED=true

# --- Log ---
LOG_LEVEL=log
